# Copy to .env and fill in. Used by the frontier-model eval runner (Phase 2).
# Never commit the real .env — it is gitignored.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Optional: Weights & Biases for training curves (used on the GPU box).
WANDB_API_KEY=...

# Optional: Hugging Face token for pushing model/dataset (used on the GPU box).
HF_TOKEN=hf_...
